// Prisma schema — v12 (quality of life)
// New in v12:
//   + UndoEntry : reversible action log, scoped per user+place
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js models ────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  accounts        Account[]
  sessions        Session[]
  ownedPlaces     Place[]           @relation("PlaceOwner")
  shares          PlaceShare[]
  createdInvites  PlaceInvitation[] @relation("InviteCreator")
  locations       Location[]
  boxes           Box[]
  undoEntries     UndoEntry[]
  createdAt       DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ─── Place / share / invite ────────────────────────────────────────
model Place {
  id          String   @id @default(cuid())
  name        String
  description String?
  ownerId     String
  owner       User     @relation("PlaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  shares      PlaceShare[]
  invitations PlaceInvitation[]
  locations   Location[]
  boxes       Box[]
  undoEntries UndoEntry[]
  createdAt   DateTime @default(now())
  @@index([ownerId])
}

model PlaceShare {
  id        String   @id @default(cuid())
  placeId   String
  userId    String
  role      String   @default("viewer")
  createdAt DateTime @default(now())
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([placeId, userId])
  @@index([userId])
}

model PlaceInvitation {
  id         String    @id @default(cuid())
  placeId    String
  place      Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  createdById String
  createdBy  User      @relation("InviteCreator", fields: [createdById], references: [id], onDelete: Cascade)
  kind       String
  role       String    @default("viewer")
  email      String?
  token      String?   @unique
  maxUses    Int?
  usedCount  Int       @default(0)
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  @@index([placeId])
  @@index([email])
}

// Reversible action log. Kept short (last 20 per user per place).
// `payload` stores the INVERSE operation to perform on undo, as JSON.
// For example, moving a box from A→B records { boxId, toLocationId: A, toStackIndex: 0 }.
model UndoEntry {
  id        String   @id @default(cuid())
  userId    String
  placeId   String
  kind      String   // "move_box" | "reorder_box" | "edit_box" | "create_box" | "delete_box"
  payload   Json     // inverse action payload
  label     String   // human-readable description for UI
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  @@index([userId, placeId, createdAt])
}

// ─── Domain ────────────────────────────────────────────────────────
model Location {
  id        String   @id @default(cuid())
  placeId   String
  userId    String
  code      String
  aisle     String
  slot      Int
  row       Int
  col       Int
  type      String   @default("cell")
  capacity  Int      @default(5)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  boxes     Box[]
  @@unique([placeId, code])
  @@index([placeId, row, col])
}

model Box {
  id          String    @id @default(cuid())
  placeId     String
  userId      String
  name        String
  description String?
  tags        String    @default("")
  photoUrl    String?
  color       String    @default("#e8602c")
  locationId  String?
  stackIndex  Int       @default(0)
  place       Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  location    Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  moves       Move[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  @@index([placeId])
  @@index([locationId, stackIndex])
}

model Move {
  id             String   @id @default(cuid())
  boxId          String
  box            Box      @relation(fields: [boxId], references: [id], onDelete: Cascade)
  fromCode       String?
  toCode         String?
  fromStackIndex Int?
  toStackIndex   Int?
  reason         String   @default("move")
  createdAt      DateTime @default(now())
  @@index([boxId, createdAt])
}
