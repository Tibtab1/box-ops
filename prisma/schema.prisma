// Prisma schema — v9 (Postgres edition for deployment)
// Only difference from v8: datasource provider switched from sqlite to postgresql.
// All models stay identical; Prisma abstracts the rest.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js models ────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  accounts      Account[]
  sessions      Session[]
  locations     Location[]
  boxes         Box[]
  createdAt     DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Domain models ─────────────────────────────────────────────────
model Location {
  id        String   @id @default(cuid())
  userId    String
  code      String
  aisle     String
  slot      Int
  row       Int
  col       Int
  type      String   @default("cell")
  capacity  Int      @default(5)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  boxes     Box[]

  @@unique([userId, code])
  @@index([userId, row, col])
}

model Box {
  id          String    @id @default(cuid())
  userId      String
  name        String
  description String?
  tags        String    @default("")
  photoUrl    String?
  color       String    @default("#e8602c")
  locationId  String?
  stackIndex  Int       @default(0)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  location    Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  moves       Move[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([locationId, stackIndex])
}

model Move {
  id             String   @id @default(cuid())
  boxId          String
  box            Box      @relation(fields: [boxId], references: [id], onDelete: Cascade)
  fromCode       String?
  toCode         String?
  fromStackIndex Int?
  toStackIndex   Int?
  reason         String   @default("move")
  createdAt      DateTime @default(now())

  @@index([boxId, createdAt])
}
