// Prisma schema — v10 (multi-Lieu / multi-Place)
// Changes from v9:
//   + Place     : a user-owned container (garage, cave, rented storage unit, ...)
//   + PlaceShare: will power sharing in iteration 2 (role = viewer/editor/admin)
//   - Location  : now tied to a Place (placeId) instead of directly to a User
//   - Box       : now tied to a Place (placeId). userId kept for backwards-compat
//                 queries (e.g. "boxes created by me") but not used for scoping.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js models ────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  accounts      Account[]
  sessions      Session[]
  ownedPlaces   Place[]       @relation("PlaceOwner")
  shares        PlaceShare[]
  locations     Location[]    // created-by, kept for compat
  boxes         Box[]         // created-by, kept for compat
  createdAt     DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ─── Place: the container ("Mon Garage", "Cave Papa", ...) ────────
model Place {
  id          String   @id @default(cuid())
  name        String
  description String?
  ownerId     String
  owner       User     @relation("PlaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  shares      PlaceShare[]
  locations   Location[]
  boxes       Box[]
  createdAt   DateTime @default(now())

  @@index([ownerId])
}

// Reserved for iteration 2 — sharing model
model PlaceShare {
  id        String   @id @default(cuid())
  placeId   String
  userId    String
  role      String   @default("viewer") // "viewer" | "editor" | "admin"
  createdAt DateTime @default(now())
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([placeId, userId])
  @@index([userId])
}

// ─── Domain models ─────────────────────────────────────────────────
model Location {
  id        String   @id @default(cuid())
  placeId   String
  userId    String   // creator, for audit/compat (not for scoping)
  code      String
  aisle     String
  slot      Int
  row       Int
  col       Int
  type      String   @default("cell")
  capacity  Int      @default(5)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  boxes     Box[]

  @@unique([placeId, code])
  @@index([placeId, row, col])
}

model Box {
  id          String    @id @default(cuid())
  placeId     String
  userId      String    // creator
  name        String
  description String?
  tags        String    @default("")
  photoUrl    String?
  color       String    @default("#e8602c")
  locationId  String?
  stackIndex  Int       @default(0)
  place       Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  location    Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  moves       Move[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([placeId])
  @@index([locationId, stackIndex])
}

model Move {
  id             String   @id @default(cuid())
  boxId          String
  box            Box      @relation(fields: [boxId], references: [id], onDelete: Cascade)
  fromCode       String?
  toCode         String?
  fromStackIndex Int?
  toStackIndex   Int?
  reason         String   @default("move")
  createdAt      DateTime @default(now())

  @@index([boxId, createdAt])
}
