# ─── Database ──────────────────────────────────────────────────────
# In development: your local Postgres (or use Neon directly)
# In production on Vercel: paste the Neon connection string (pooled)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# ─── Auth.js ───────────────────────────────────────────────────────
# Generate with: npm run auth:secret
AUTH_SECRET=""

# Google OAuth — get these at https://console.cloud.google.com/
# Leave empty to disable Google login.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Only needed in development. On Vercel, AUTH_URL is auto-detected from VERCEL_URL.
AUTH_TRUST_HOST="true"
