// Prisma schema — v13 (furniture)
// New in v13:
//   + Box.kind      : "box" (default) | "furniture"
//   + Box.spanW     : footprint width in cells (1-3, default 1)
//   + Box.spanH     : footprint height in cells (1-3, default 1)
//   + Box.parentId  : if set, this box is "inside" a furniture item and does
//                     not appear on the main plan. locationId is null in that case.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js models ────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  accounts        Account[]
  sessions        Session[]
  ownedPlaces     Place[]           @relation("PlaceOwner")
  shares          PlaceShare[]
  createdInvites  PlaceInvitation[] @relation("InviteCreator")
  locations       Location[]
  boxes           Box[]
  undoEntries     UndoEntry[]
  createdAt       DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ─── Place / share / invite ────────────────────────────────────────
model Place {
  id          String   @id @default(cuid())
  name        String
  description String?
  ownerId     String
  owner       User     @relation("PlaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  shares      PlaceShare[]
  invitations PlaceInvitation[]
  locations   Location[]
  boxes       Box[]
  undoEntries UndoEntry[]
  createdAt   DateTime @default(now())
  @@index([ownerId])
}

model PlaceShare {
  id        String   @id @default(cuid())
  placeId   String
  userId    String
  role      String   @default("viewer")
  createdAt DateTime @default(now())
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([placeId, userId])
  @@index([userId])
}

model PlaceInvitation {
  id         String    @id @default(cuid())
  placeId    String
  place      Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  createdById String
  createdBy  User      @relation("InviteCreator", fields: [createdById], references: [id], onDelete: Cascade)
  kind       String
  role       String    @default("viewer")
  email      String?
  token      String?   @unique
  maxUses    Int?
  usedCount  Int       @default(0)
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  @@index([placeId])
  @@index([email])
}

model UndoEntry {
  id        String   @id @default(cuid())
  userId    String
  placeId   String
  kind      String
  payload   Json
  label     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  @@index([userId, placeId, createdAt])
}

// ─── Domain ────────────────────────────────────────────────────────
model Location {
  id        String   @id @default(cuid())
  placeId   String
  userId    String
  code      String
  aisle     String
  slot      Int
  row       Int
  col       Int
  type      String   @default("cell")
  capacity  Int      @default(5)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  boxes     Box[]
  @@unique([placeId, code])
  @@index([placeId, row, col])
}

model Box {
  id          String    @id @default(cuid())
  placeId     String
  userId      String
  name        String
  description String?
  tags        String    @default("")
  photoUrl    String?
  color       String    @default("#e8602c")
  kind        String    @default("box")     // "box" | "furniture" | "flat"
  spanW       Int       @default(1)         // 1..3 (furniture only)
  spanH       Int       @default(1)         // 1..3 (furniture only)
  locationId  String?                       // null when parentId is set
  stackIndex  Int       @default(0)
  parentId    String?                       // if set, this box lives inside a furniture item
  // Flat (frame/painting) specific fields — nullable, only populated when kind = "flat"
  widthCm             Int?
  heightCm            Int?
  flatType            String?               // "painting" | "photo" | "poster" | "mirror" | "other"
  isFragile           Boolean  @default(false)
  estimatedValueCents Int?                  // value in cents (e.g. 12500 = 125,00 €)
  // v2 flat positioning: a flat is an edge between two cells (or a cell and outer space)
  flatEdgeRowA        Int?
  flatEdgeColA        Int?
  flatEdgeRowB        Int?
  flatEdgeColB        Int?
  place       Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  location    Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  parent      Box?      @relation("BoxContents", fields: [parentId], references: [id], onDelete: SetNull)
  children    Box[]     @relation("BoxContents")
  moves       Move[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  @@index([placeId])
  @@index([locationId, stackIndex])
  @@index([parentId, stackIndex])
}

model Move {
  id             String   @id @default(cuid())
  boxId          String
  box            Box      @relation(fields: [boxId], references: [id], onDelete: Cascade)
  fromCode       String?
  toCode         String?
  fromStackIndex Int?
  toStackIndex   Int?
  reason         String   @default("move")
  createdAt      DateTime @default(now())
  @@index([boxId, createdAt])
}
